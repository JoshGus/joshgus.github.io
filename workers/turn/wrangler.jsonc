{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "joshgus-turn",
  "main": "src/index.js",
  "compatibility_date": "2026-07-01",
  "observability": { "enabled": true },
  "vars": {
    // Not a secret — the ID is meaningless without the API token.
    // Set with: wrangler secret put TURN_KEY_API_TOKEN
    "TURN_KEY_ID": "REPLACE_WITH_YOUR_TURN_KEY_ID"
  }
}
